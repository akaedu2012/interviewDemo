# AI 简历分析平台 - 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# =============================================================================
# AI API 配置
# =============================================================================

# OpenAI API 配置（如果使用 OpenAI）
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API 配置（如果使用 Claude）
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# =============================================================================
# 数据库配置
# =============================================================================

# SQLite 数据库文件路径（相对于项目根目录）
DATABASE_PATH=./data/resume-analyzer.db

# =============================================================================
# 文件上传配置
# =============================================================================

# 文件上传目录（相对于 public 目录）
UPLOAD_DIR=uploads

# 最大文件大小（字节）
MAX_FILE_SIZE=10485760

# 最大同时上传文件数
MAX_FILES=5

# =============================================================================
# 应用配置
# =============================================================================

# 应用运行环境（development, production, test）
NODE_ENV=development

# 应用端口
PORT=3000

# 应用基础 URL（用于生成完整URL，如邮件链接等）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别（DEBUG, INFO, WARN, ERROR）
LOG_LEVEL=DEBUG

# 是否启用控制台日志
LOG_CONSOLE=true

# 是否启用远程日志服务
LOG_REMOTE=false

# 远程日志服务地址（可选）
# LOG_REMOTE_ENDPOINT=https://your-log-service.com/api/logs

# =============================================================================
# 安全配置（生产环境）
# =============================================================================

# API 密钥（用于保护敏感 API 端点，可选）
# API_SECRET_KEY=your-secret-key-here

# CORS 允许的域名（逗号分隔，可选）
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# 第三方服务配置（可选）
# =============================================================================

# 云存储配置（如果使用 S3 或其他对象存储）
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# 监控和分析服务（可选）
# SENTRY_DSN=your-sentry-dsn
# GA_TRACKING_ID=your-google-analytics-id

# =============================================================================
# 开发配置（仅开发环境）
# =============================================================================

# 是否启用详细错误日志
DEV_VERBOSE_ERRORS=true

# 是否启用热重载
# NEXT_PUBLIC_DEV_HOT_RELOAD=true
